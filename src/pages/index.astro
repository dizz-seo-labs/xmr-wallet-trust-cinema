---
import { SITE, pageCluster, homepageFaq } from '../data/pages.js';
import { editorial, coreSources } from '../data/seoExtras.js';
const title = 'Cake Wallet Safety Field Manual: Independent Monero Wallet Guides';
const description = 'Independent Cake Wallet and Monero safety field manual: avoid seed phrase phishing, fake support, unsafe restore flows, privacy overclaims, and risky wallet downloads.';
const canonical = `${SITE.url}/`;
const image = `${SITE.url}${SITE.image}`;
const manualEntries = pageCluster;
const moments = [
  ['I am about to restore a wallet', 'Stop before typing recovery words anywhere. Restore only inside verified wallet software, then check restore-height context.', 'restore-cake-wallet'],
  ['I found a Cake Wallet login page', 'Assume a web login result is unsafe until the official source path proves otherwise. Ordinary navigation should not require a seed phrase.', 'cake-wallet-login-safety'],
  ['A support account messaged me', 'Do not continue in private chat if anyone asks for recovery words, wallet files, screenshots, or remote-control access.', 'cake-wallet-support-scam-warning'],
  ['I want better Monero privacy', 'Treat privacy as a workflow: exchange records, device risk, network habits, and screenshots still matter.', 'cake-wallet-privacy-limits']
];
const route = [
  ['01', 'Source path', 'Start at cakewallet.com or official app-store listings. Do not use ads, cloned APK pages, or copied social links as final proof.'],
  ['02', 'Device check', 'Update the wallet and device from trusted paths. Avoid restore or send flows on a device that feels compromised.'],
  ['03', 'Recovery boundary', 'Recovery words stay offline and inside verified wallet software only. No website or support account gets them.'],
  ['04', 'Small test', 'Before meaningful funds move, test with a small receive/send path and write down non-sensitive steps that worked.']
];
const sourceLadder = [
  ['Official website', 'Use the public Cake Wallet site as the first source path, then verify any install or support path against it.'],
  ['App-store listing', 'Check publisher details, update history, support links, and whether the listing asks for anything a wallet install should not need.'],
  ['Project docs', 'Use public docs and release notes to understand restore height, backup, and wallet behavior without exposing secrets.'],
  ['This field manual', 'Use this site only as an independent checklist. It is not support and it never collects wallet material.']
];
const collectionSchema = { '@context': 'https://schema.org', '@type': 'CollectionPage', name: title, description, url: canonical, inLanguage: 'en', isPartOf: { '@type': 'WebSite', name: SITE.name, url: SITE.url }, about: ['Cake Wallet safety', 'Monero wallet restore', 'seed phrase backup', 'wallet support scams', 'Monero privacy limits'], publisher: { '@type': 'Organization', name: SITE.name, logo: image }, reviewedBy: { '@type': 'Organization', name: editorial.name, url: `${SITE.url}/editorial-policy/` }, mainEntity: { '@type': 'ItemList', itemListElement: pageCluster.map((p, index) => ({ '@type': 'ListItem', position: index + 1, name: p.title, url: `${SITE.url}/${p.slug}/` })) } };
const orgSchema = { '@context': 'https://schema.org', '@type': 'WebSite', name: SITE.name, url: SITE.url, about: ['Cake Wallet safety', 'Monero wallet restore', 'seed phrase backup', 'wallet support scams', 'Monero privacy limits'], publisher: { '@type': 'Organization', name: SITE.name, logo: image } };
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#f4ead7" />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)}></script>
    <style is:global>
      :root{color-scheme:light;--paper:#f4ead7;--paper2:#fff8eb;--ink:#16130f;--muted:#6b6257;--line:#1e1a1430;--orange:#ff6b1a;--orange2:#f0441f;--charcoal:#181512;--green:#1f8c5c;--blue:#285d8f;--cream:#fffdf6;--shadow:rgba(40,28,12,.18);font-family:ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif}*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:var(--paper);color:var(--ink);letter-spacing:-.015em}body::before{content:"";position:fixed;inset:0;pointer-events:none;opacity:.36;background-image:linear-gradient(rgba(22,19,15,.05) 1px,transparent 1px),linear-gradient(90deg,rgba(22,19,15,.035) 1px,transparent 1px);background-size:32px 32px,32px 32px}a{color:inherit}.wrap{width:min(1180px,calc(100% - 36px));margin:0 auto}.rule-strip{background:var(--charcoal);color:#fff;border-bottom:4px solid var(--orange);font-size:14px}.rule-strip .wrap{display:flex;justify-content:space-between;gap:18px;align-items:center;padding:10px 0}.rule-strip strong{color:#ffd1b9}.nav{position:sticky;top:0;z-index:20;background:rgba(244,234,215,.88);backdrop-filter:blur(14px);border-bottom:1px solid var(--line)}.nav-inner{min-height:70px;display:flex;align-items:center;justify-content:space-between;gap:24px}.brand{display:flex;align-items:center;gap:12px;text-decoration:none;font-weight:950}.brand-mark{width:42px;height:42px;border:2px solid var(--ink);border-radius:50%;display:grid;place-items:center;background:var(--orange);box-shadow:4px 4px 0 var(--ink);transform:rotate(-8deg)}.nav-links{display:flex;gap:18px;align-items:center;flex-wrap:wrap;font-size:14px}.nav-links a{text-decoration:none;border-bottom:1px solid transparent}.nav-links a:hover{border-color:var(--ink)}.sponsor-nav{background:var(--ink);color:#fff;border-radius:999px;padding:11px 16px;text-decoration:none;font-weight:850}.hero{padding:70px 0 42px}.hero-grid{display:grid;grid-template-columns:minmax(0,1fr) 420px;gap:48px;align-items:start}.kicker{font-size:13px;font-weight:950;letter-spacing:.14em;text-transform:uppercase;color:var(--orange2);margin:0 0 16px}.hero h1{font-family:Georgia,"Times New Roman",serif;font-weight:500;font-size:clamp(56px,9vw,112px);line-height:.86;letter-spacing:-.075em;margin:0 0 22px;max-width:820px}.hero h1 em{font-style:italic;color:var(--orange2)}.lead{font-size:clamp(19px,2vw,25px);line-height:1.35;max-width:780px;margin:0;color:#2f2a24}.no-list{list-style:none;margin:30px 0 0;padding:0;display:grid;gap:8px;max-width:620px}.no-list li{font-family:Georgia,"Times New Roman",serif;font-size:clamp(25px,4vw,48px);line-height:.98}.no-list b{color:var(--orange2);font-style:italic}.actions{display:flex;gap:12px;flex-wrap:wrap;margin-top:30px}.btn{display:inline-flex;align-items:center;justify-content:center;text-decoration:none;border:2px solid var(--ink);border-radius:999px;padding:13px 18px;font-weight:950;box-shadow:4px 4px 0 var(--ink);background:var(--orange);color:var(--ink)}.btn.secondary{background:var(--cream)}.note{max-width:760px;color:var(--muted);font-size:13px;line-height:1.45;margin:18px 0 0}.dossier{position:relative;background:var(--cream);border:2px solid var(--ink);box-shadow:12px 12px 0 var(--ink);padding:24px;transform:rotate(1.2deg)}.dossier::before{content:"SEED PHRASE QUARANTINE";position:absolute;top:-18px;left:22px;background:var(--orange);border:2px solid var(--ink);padding:6px 10px;font-size:12px;font-weight:950;letter-spacing:.08em;transform:rotate(-3deg)}.stamp{border:3px solid var(--orange2);color:var(--orange2);font-weight:1000;font-size:46px;line-height:.9;text-align:center;padding:16px 8px;transform:rotate(-7deg);margin:18px 0 26px;text-transform:uppercase}.seed-slip{border:1px dashed var(--muted);padding:16px;background:#f2eadc}.seed-slip span{display:block;font-family:ui-monospace,Menlo,monospace;letter-spacing:.18em;background:#211c16;color:#211c16;margin:8px 0;border-radius:2px}.field-meta{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:22px}.field-meta div{border-top:2px solid var(--ink);padding-top:8px;font-size:13px;color:var(--muted)}section{padding:58px 0}.section-head{display:grid;grid-template-columns:.8fr 1.2fr;gap:30px;align-items:end;margin-bottom:26px}.section-head h2{font-family:Georgia,"Times New Roman",serif;font-size:clamp(38px,6vw,76px);line-height:.9;letter-spacing:-.06em;margin:0}.section-head p{font-size:19px;line-height:1.45;color:var(--muted);margin:0}.moment-grid{display:grid;grid-template-columns:repeat(4,1fr);border:2px solid var(--ink);background:var(--ink);gap:2px}.moment{background:var(--paper2);padding:22px;text-decoration:none;min-height:250px;display:flex;flex-direction:column;justify-content:space-between}.moment strong{font-family:Georgia,"Times New Roman",serif;font-size:25px;line-height:1.05}.moment p{color:var(--muted);line-height:1.45}.moment span{font-weight:950;color:var(--orange2)}.route{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}.route-card{background:var(--charcoal);color:#fff;padding:22px;border-radius:2px;min-height:250px;position:relative;overflow:hidden}.route-card::after{content:attr(data-step);position:absolute;right:8px;bottom:-16px;font-family:Georgia,"Times New Roman",serif;font-size:110px;color:rgba(255,255,255,.08)}.route-card h3{margin:0 0 12px;font-size:25px}.route-card p{color:#d9d0c5;line-height:1.48}.ledger{border:2px solid var(--ink);background:var(--cream)}.ledger-row{display:grid;grid-template-columns:90px 1fr 150px;gap:16px;align-items:center;padding:20px;border-bottom:2px solid var(--ink);text-decoration:none}.ledger-row:last-child{border-bottom:0}.ledger-num{font-family:ui-monospace,Menlo,monospace;color:var(--orange2);font-weight:950}.ledger-row h3{margin:0;font-size:24px;line-height:1.05}.ledger-row p{margin:6px 0 0;color:var(--muted);line-height:1.4}.ledger-row span{font-weight:950;text-align:right}.source-ladder{display:grid;grid-template-columns:1fr 1fr;gap:18px}.source-item{background:var(--paper2);border:2px solid var(--ink);padding:24px;box-shadow:6px 6px 0 var(--shadow)}.source-item h3{font-family:Georgia,"Times New Roman",serif;font-size:33px;margin:0 0 10px}.source-item p{color:var(--muted);line-height:1.52}.stop-panel{background:var(--orange2);color:#fff;border:2px solid var(--ink);box-shadow:10px 10px 0 var(--ink);padding:clamp(28px,5vw,54px);display:grid;grid-template-columns:1fr 1fr;gap:24px}.stop-panel h2{font-family:Georgia,"Times New Roman",serif;font-size:clamp(44px,7vw,88px);line-height:.88;letter-spacing:-.065em;margin:0}.stop-panel ul{margin:0;padding-left:18px;line-height:1.75;font-weight:750}.faq details{border-top:2px solid var(--ink);padding:18px 0}.faq summary{cursor:pointer;font-size:22px;font-weight:950}.faq p{max-width:760px;color:var(--muted);line-height:1.55}.footer{margin-top:60px;background:var(--charcoal);color:#f5eadb;padding:46px 0}.footer-grid{display:grid;grid-template-columns:1.3fr repeat(3,1fr);gap:28px}.footer h3{margin:0 0 12px;font-family:Georgia,"Times New Roman",serif;font-size:28px}.footer a{display:block;color:#f5eadb;text-decoration:none;margin:8px 0}.footer p{color:#c9bcad;line-height:1.55}.template-note{display:none}@media(max-width:980px){.hero-grid,.section-head,.source-ladder,.stop-panel,.footer-grid{grid-template-columns:1fr}.moment-grid,.route{grid-template-columns:1fr 1fr}.dossier{transform:none}.ledger-row{grid-template-columns:70px 1fr}.ledger-row span{grid-column:2;text-align:left}.nav-inner{align-items:flex-start;flex-direction:column;padding:14px 0}}@media(max-width:560px){.wrap{width:min(100% - 24px,1180px)}.rule-strip .wrap{align-items:flex-start;flex-direction:column}.moment-grid,.route{grid-template-columns:1fr}.hero{padding-top:44px}.hero h1{font-size:55px}.no-list li{font-size:31px}.stamp{font-size:34px}.footer-grid{gap:18px}}@media(prefers-reduced-motion:reduce){*,*::before,*::after{animation:none!important;transition:none!important;scroll-behavior:auto!important}}
    </style>
  </head>
  <body>
    <div class="template-note">Selected direction: Seed Phrase Quarantine Field Manual. Mobbin references translated as editorial security patterns, not copied UI.</div>
    <div class="rule-strip"><div class="wrap"><span><strong>Emergency rule:</strong> never type a recovery phrase into a website.</span><span>Independent guide · no wallet data collection</span></div></div>
    <nav class="nav"><div class="wrap nav-inner"><a class="brand" href="/"><span class="brand-mark">X</span><span>XMR Safety Field Manual</span></a><div class="nav-links"><a href="#moments">Start here</a><a href="#route">Safe route</a><a href="#manual">Manual entries</a><a href="/about/">About</a><a href="/editorial-policy/">Editorial policy</a><a class="sponsor-nav" href={SITE.referralUrl} target="_blank" rel="sponsored nofollow noopener">Continue after checks</a></div></div></nav>
    <main>
      <section class="hero wrap">
        <div class="hero-grid">
          <div>
            <p class="kicker">Cake Wallet / Monero safety field manual</p>
            <h1>Do not let a rushed wallet moment become a <em>seed leak.</em></h1>
            <p class="lead">Independent, practical checks for Cake Wallet downloads, restore flows, support scams, Monero privacy limits, and self-custody decisions.</p>
            <ul class="no-list"><li><b>No</b> seed on websites</li><li><b>No</b> fake support DMs</li><li><b>No</b> screenshots of recovery words</li></ul>
            <div class="actions"><a class="btn" href="#moments">Find your situation</a><a class="btn secondary" href={SITE.referralUrl} target="_blank" rel="sponsored nofollow noopener">Continue to Cake Wallet</a></div>
            <p class="note">{SITE.referralDisclosure} This resource is independent and not affiliated with Cake Wallet. Verify official wallet sources through cakewallet.com or official app stores before installing or restoring.</p>
          </div>
          <aside class="dossier" aria-label="Seed phrase quarantine card">
            <div class="stamp">Never paste your seed</div>
            <p><strong>Quarantine check:</strong> if a page, bot, ad, or helper asks for recovery words, leave the flow and verify the source path again.</p>
            <div class="seed-slip" aria-label="redacted seed phrase illustration"><small>Recovery words belong offline:</small><span>████████████████</span><span>████████████████</span><span>████████████████</span></div>
            <div class="field-meta"><div>Use: before install, restore, support, send</div><div>Status: static guide, no wallet input</div></div>
          </aside>
        </div>
      </section>
      <section class="wrap" id="moments"><div class="section-head"><h2>If you are here because...</h2><p>Pick the risky moment first. The site should route the user away from panic and toward the exact check that matters.</p></div><div class="moment-grid">{moments.map(([title,text,slug]) => <a class="moment" href={`/${slug}/`}><strong>{title}</strong><p>{text}</p><span>Open check →</span></a>)}</div></section>
      <section class="wrap" id="route"><div class="section-head"><h2>The safe route before funds move.</h2><p>No fake progress bars. No decoration. Just the four checks that change the outcome before a download, restore, or support conversation.</p></div><div class="route">{route.map(([num,title,text]) => <article class="route-card" data-step={num}><h3>{title}</h3><p>{text}</p></article>)}</div></section>
      <section class="wrap" id="manual"><div class="section-head"><h2>Manual entries, not generic blog cards.</h2><p>Every page serves a specific Cake Wallet or Monero safety intent and keeps the non-affiliation boundary visible.</p></div><div class="ledger">{manualEntries.map((p, index) => <a class="ledger-row" href={`/${p.slug}/`}><div class="ledger-num">ENTRY {String(index + 1).padStart(2,'0')}</div><div><h3>{p.title}</h3><p>{p.directAnswer}</p></div><span>Read →</span></a>)}</div></section>
      <section class="wrap"><div class="section-head"><h2>Source ladder.</h2><p>Use this site as a checklist, not authority theater. The real proof path starts with official sources and ends with your own careful action.</p></div><div class="source-ladder">{sourceLadder.map(([title,text]) => <article class="source-item"><h3>{title}</h3><p>{text}</p></article>)}</div></section>
      <section class="wrap"><div class="stop-panel"><h2>Stop immediately if...</h2><ul><li>a website asks for recovery words or private keys;</li><li>a helper moves you into a private chat and asks for screenshots;</li><li>a download page creates urgency without a verifiable source path;</li><li>a support account promises to restore funds if you share wallet material.</li></ul></div></section>
      <section class="wrap"><div class="section-head"><h2>Why this guide should be easier to trust.</h2><p>The site shows its editorial boundaries, source trail, non-affiliation status, and people-first purpose instead of acting like a thin affiliate doorway.</p></div><div class="source-ladder"><article class="source-item"><h3>Reviewed, not auto-stuffed</h3><p>{editorial.policy}</p></article><article class="source-item"><h3>Visible source trail</h3><p>{coreSources.map(([name]) => name).join(' · ')}</p></article><article class="source-item"><h3>No unsupported promises</h3><p>No anonymity guarantees, recovery promises, official-support claims, or wallet-data collection.</p></article><article class="source-item"><h3>Sponsored link disclosed</h3><p>The Cake Wallet CTA is labeled as sponsored, uses the correct rel attributes, and stays secondary to safety checks.</p></article></div></section>
      <section class="wrap faq"><div class="section-head"><h2>Fast answers without the trap.</h2><p>Short answers for users who are one bad click away from a permanent mistake.</p></div>{homepageFaq.map(([q,a]) => <details><summary>{q}</summary><p>{a}</p></details>)}</section>
    </main>
    <footer class="footer"><div class="wrap footer-grid"><div><h3>XMR Safety Field Manual</h3><p>{SITE.disclosure} The site is static, educational, and never asks for recovery phrases, private keys, wallet files, screenshots, or personal wallet details.</p><a href="/about/">About this site</a><a href="/editorial-policy/">Editorial policy</a></div><div><h3>Start</h3><a href="/cake-wallet-login-safety/">Login safety</a><a href="/restore-cake-wallet/">Restore checklist</a><a href="/cake-wallet-official-download-check/">Download source</a></div><div><h3>Risks</h3><a href="/cake-wallet-support-scam-warning/">Fake support</a><a href="/cake-wallet-seed-phrase-backup/">Seed backup</a><a href="/cake-wallet-privacy-limits/">Privacy limits</a></div><div><h3>Reference</h3><a href="/monero-restore-height-guide/">Restore height</a><a href="/non-custodial-wallet-safety/">Non-custodial safety</a><a href="/cake-wallet-faq/">FAQ</a></div></div></footer>
  </body>
</html>
