---
import { SITE } from '../data/pages.js';
import { editorial, coreSources } from '../data/seoExtras.js';
const title = 'About XMR Wallet Safety Guide';
const description = 'About the independent XMR Wallet Safety Guide: purpose, non-affiliation, source boundaries, and what this site will never ask users to share.';
const canonical = `${SITE.url}/about/`;
const image = `${SITE.url}${SITE.image}`;
const schema = { '@context': 'https://schema.org', '@type': 'AboutPage', name: title, description, url: canonical, inLanguage: 'en', isPartOf: { '@type': 'WebSite', name: SITE.name, url: SITE.url }, publisher: { '@type': 'Organization', name: SITE.name, logo: image }, reviewedBy: { '@type': 'Organization', name: editorial.name, url: `${SITE.url}/editorial-policy/` } };
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
    <style is:global>
      :root{color-scheme:light;--paper:#f4ead7;--paper2:#fff8eb;--ink:#16130f;--muted:#6b6257;--line:#1e1a1430;--orange:#ff6b1a;--charcoal:#181512;--cream:#fffdf6;font-family:ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif}*{box-sizing:border-box}body{margin:0;background:var(--paper);color:var(--ink);letter-spacing:-.015em}body::before{content:"";position:fixed;inset:0;pointer-events:none;opacity:.28;background-image:linear-gradient(rgba(22,19,15,.05) 1px,transparent 1px);background-size:32px 32px}.wrap{width:min(980px,calc(100% - 36px));margin:0 auto}.rule{background:var(--charcoal);color:#fff;border-bottom:4px solid var(--orange)}.rule .wrap{padding:10px 0;display:flex;justify-content:space-between;gap:18px}.nav{position:sticky;top:0;background:rgba(244,234,215,.9);backdrop-filter:blur(14px);border-bottom:1px solid var(--line)}.nav .wrap{min-height:66px;display:flex;align-items:center;justify-content:space-between;gap:18px}.brand{font-weight:950;text-decoration:none}.nav a{color:inherit}.links{display:flex;gap:14px;flex-wrap:wrap}.links a{text-decoration:none}.hero{padding:70px 0 28px}.kicker{font-size:13px;font-weight:950;letter-spacing:.14em;text-transform:uppercase;color:#f0441f}.hero h1{font-family:Georgia,"Times New Roman",serif;font-size:clamp(48px,8vw,92px);line-height:.9;letter-spacing:-.065em;margin:12px 0 18px}.lead{font-size:clamp(20px,2.2vw,28px);line-height:1.35;color:#302a24;max-width:880px}.section{background:var(--cream);border:2px solid var(--ink);box-shadow:6px 6px 0 rgba(40,28,12,.18);padding:clamp(22px,4vw,34px);margin:18px 0}.section h2{font-family:Georgia,"Times New Roman",serif;font-size:clamp(32px,5vw,58px);line-height:.92;margin:0 0 18px}.grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}.card{background:var(--paper2);border:2px solid var(--ink);padding:16px}.card p,.section p,.section li{color:var(--muted);line-height:1.6;font-weight:620}.footer{border-top:2px solid var(--ink);padding:34px 0;color:var(--muted)}@media(max-width:720px){.rule .wrap,.nav .wrap{align-items:flex-start;flex-direction:column}.grid{grid-template-columns:1fr}}
    </style>
  </head>
  <body>
    <div class="rule"><div class="wrap"><span><strong>Emergency rule:</strong> never type a recovery phrase into a website.</span><span>Independent guide</span></div></div>
    <nav class="nav"><div class="wrap"><a class="brand" href="/">XMR Safety Field Manual</a><div class="links"><a href="/">Hub</a><a href="/editorial-policy/">Editorial policy</a><a href="/cake-wallet-faq/">FAQ</a></div></div></nav>
    <main class="wrap">
      <header class="hero"><p class="kicker">About this site</p><h1>Independent safety guidance for risky wallet moments.</h1><p class="lead">XMR Wallet Safety Guide is a static educational site for Cake Wallet and Monero self-custody safety questions. It is not official Cake Wallet support, not a wallet app, not a recovery service, and not financial advice.</p></header>
      <section class="section"><h2>What this site does</h2><div class="grid"><article class="card"><strong>Slows down dangerous actions</strong><p>The site helps users pause before installs, restores, support chats, privacy assumptions, and seed-phrase handling.</p></article><article class="card"><strong>Routes users to source checks</strong><p>Guides point users back to official websites, app-store listings, public documentation, and safe non-sensitive troubleshooting.</p></article><article class="card"><strong>Keeps sponsorship visible</strong><p>Sponsored links are disclosed and marked with sponsored/nofollow/noopener attributes.</p></article><article class="card"><strong>Does not collect wallet data</strong><p>No forms, no seed phrase input, no private keys, no wallet files, no screenshots, and no support-ticket collection.</p></article></div></section>
      <section class="section"><h2>Public source trail</h2><div class="grid">{coreSources.map(([name,url,note]) => <article class="card"><strong><a href={url} target="_blank" rel="noopener">{name}</a></strong><p>{note}</p></article>)}</div></section>
      <section class="section"><h2>Boundaries</h2><ul><li>{SITE.disclosure}</li><li>No official support impersonation.</li><li>No financial, legal, privacy, security, recovery, or anonymity guarantees.</li><li>No advice to share recovery phrases, private keys, wallet files, screenshots, or remote-control access.</li></ul></section>
    </main>
    <footer class="footer wrap">Read the <a href="/editorial-policy/">editorial policy</a> or return to the <a href="/">field manual</a>.</footer>
  </body>
</html>
