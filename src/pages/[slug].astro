---
import { SITE, pageCluster } from '../data/pages.js';
import { editorial, pageDepth, sourcesFor, stopSignalsFor } from '../data/seoExtras.js';
export function getStaticPaths() { return pageCluster.map((page) => ({ params: { slug: page.slug }, props: { page } })); }
const { page } = Astro.props;
const canonical = `${SITE.url}/${page.slug}/`;
const image = `${SITE.url}${SITE.image}`;
const published = '2026-05-01';
const modified = editorial.lastReviewed;
const depth = pageDepth[page.slug] || {};
const related = pageCluster.filter((p) => p.slug !== page.slug).slice(0,5);
const contextual = page.contextualLinks || [];
const fallbackSections = [
  { heading: 'First, name the risky moment', body: page.scene },
  { heading: 'Then use the checklist before acting', body: page.directAnswer },
  { heading: 'Keep the boundary visible', body: 'This guide is independent education. It does not provide official support, does not verify wallets, and does not need recovery phrases, private keys, wallet files, screenshots, or account details.' }
];
const sections = depth.sections || page.sections || fallbackSections;
const sourceTrail = sourcesFor(page);
const stopSignals = stopSignalsFor();
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: page.title,
  description: page.description,
  url: canonical,
  mainEntityOfPage: canonical,
  image,
  inLanguage: 'en',
  about: page.intent,
  keywords: [page.intent, 'Cake Wallet safety', 'Monero wallet safety', 'seed phrase safety', 'wallet phishing'],
  datePublished: published,
  dateModified: modified,
  author: { '@type': 'Organization', name: editorial.name, url: `${SITE.url}/editorial-policy/` },
  reviewedBy: { '@type': 'Organization', name: editorial.name, url: `${SITE.url}/editorial-policy/` },
  publisher: { '@type': 'Organization', name: SITE.name, logo: image },
  isPartOf: { '@type': 'WebSite', name: SITE.name, url: SITE.url },
  citation: sourceTrail.map(([,url]) => url)
};
const breadcrumbSchema = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE.url}/` }, { '@type': 'ListItem', position: 2, name: 'Manual entries', item: `${SITE.url}/#manual` }, { '@type': 'ListItem', position: 3, name: page.title, item: canonical }] };
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{page.title}</title>
    <meta name="description" content={page.description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta property="og:title" content={page.title} />
    <meta property="og:description" content={page.description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={page.title} />
    <meta name="twitter:description" content={page.description} />
    <meta name="twitter:image" content={image} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#f4ead7" />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
    <style is:global>
      :root{color-scheme:light;--paper:#f4ead7;--paper2:#fff8eb;--ink:#16130f;--muted:#6b6257;--line:#1e1a1430;--orange:#ff6b1a;--orange2:#f0441f;--charcoal:#181512;--cream:#fffdf6;--shadow:rgba(40,28,12,.18);font-family:ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif}*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:var(--paper);color:var(--ink);letter-spacing:-.015em}body::before{content:"";position:fixed;inset:0;pointer-events:none;opacity:.32;background-image:linear-gradient(rgba(22,19,15,.05) 1px,transparent 1px);background-size:32px 32px}a{color:inherit}.wrap{width:min(1040px,calc(100% - 36px));margin:0 auto}.rule-strip{background:var(--charcoal);color:#fff;border-bottom:4px solid var(--orange);font-size:14px}.rule-strip .wrap{display:flex;justify-content:space-between;gap:18px;align-items:center;padding:10px 0}.nav{position:sticky;top:0;z-index:20;background:rgba(244,234,215,.9);backdrop-filter:blur(14px);border-bottom:1px solid var(--line)}.nav-inner{min-height:66px;display:flex;align-items:center;justify-content:space-between;gap:18px}.brand{display:flex;align-items:center;gap:10px;text-decoration:none;font-weight:950}.brand-mark{width:38px;height:38px;border:2px solid var(--ink);border-radius:50%;display:grid;place-items:center;background:var(--orange);box-shadow:4px 4px 0 var(--ink);transform:rotate(-8deg)}.nav-links{display:flex;gap:14px;align-items:center;flex-wrap:wrap;font-size:14px}.nav-links a{text-decoration:none}.breadcrumbs{display:flex;gap:8px;flex-wrap:wrap;margin:24px auto 0;font-size:13px;color:var(--muted)}.breadcrumbs a{text-decoration:none;border-bottom:1px solid var(--line)}.hero{padding:38px 0 32px}.case-grid{display:grid;grid-template-columns:1fr 300px;gap:34px;align-items:start}.kicker{font-size:13px;font-weight:950;letter-spacing:.14em;text-transform:uppercase;color:var(--orange2);margin:0 0 14px}.hero h1{font-family:Georgia,"Times New Roman",serif;font-weight:500;font-size:clamp(44px,7vw,86px);line-height:.9;letter-spacing:-.065em;margin:0 0 18px}.answer{font-size:clamp(19px,2vw,26px);line-height:1.33;color:#302a24;max-width:850px;margin:0}.case-card{background:var(--cream);border:2px solid var(--ink);box-shadow:9px 9px 0 var(--ink);padding:20px;position:relative}.case-card::before{content:"CASE FILE";position:absolute;top:-16px;left:16px;background:var(--orange);border:2px solid var(--ink);padding:5px 9px;font-size:12px;font-weight:950;letter-spacing:.08em}.case-card b{display:block;font-family:Georgia,"Times New Roman",serif;font-size:30px;line-height:1;margin:12px 0}.case-card p{color:var(--muted);line-height:1.45}.meta-strip{display:flex;gap:10px;flex-wrap:wrap;margin-top:22px}.meta-strip span{border:2px solid var(--ink);background:var(--paper2);border-radius:999px;padding:8px 11px;font-size:13px;font-weight:850}.content{padding:22px 0 70px}.section{background:var(--cream);border:2px solid var(--ink);box-shadow:6px 6px 0 var(--shadow);padding:clamp(22px,4vw,34px);margin:18px 0}.section h2{font-family:Georgia,"Times New Roman",serif;font-size:clamp(32px,5vw,58px);line-height:.92;letter-spacing:-.055em;margin:0 0 18px}.summary-list{display:grid;gap:10px;margin:0;padding:0;list-style:none}.summary-list li{border-left:6px solid var(--orange);background:var(--paper2);padding:14px 16px;font-weight:850;line-height:1.45}.checks{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;counter-reset:check}.check{border-left:6px solid var(--orange);background:var(--paper2);padding:17px;font-weight:780;line-height:1.4}.check::before{counter-increment:check;content:"CHECK " counter(check) " · ";font-family:ui-monospace,Menlo,monospace;color:var(--orange2);font-weight:950}.trust-grid,.source-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}.trust-card,.source-card{background:var(--paper2);border:2px solid var(--ink);padding:16px}.trust-card strong,.source-card strong{display:block;margin-bottom:6px}.source-card p,.trust-card p{margin:0;color:var(--muted);line-height:1.5}.source-card a{font-weight:950;text-decoration:none;border-bottom:1px solid var(--ink)}.prose article{border-top:2px solid var(--ink);padding:20px 0}.prose article:first-of-type{border-top:0}.prose h3{font-size:26px;margin:0 0 8px}.prose p,.section p,.section li{color:var(--muted);line-height:1.6;font-weight:620}.source-box{background:var(--charcoal);color:#fff}.source-box p,.source-box li{color:#d8cbbb}.stop-list{margin:0;padding-left:20px}.context-links,.cluster{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}.context-links a,.cluster a{border:2px solid var(--ink);background:var(--paper2);padding:16px;text-decoration:none;font-weight:850;box-shadow:4px 4px 0 var(--shadow)}.faq details{border-top:2px solid var(--ink);padding:16px 0}.faq summary{font-size:21px;font-weight:950;cursor:pointer}.cta{display:flex;gap:12px;flex-wrap:wrap;margin-top:22px}.btn{display:inline-flex;align-items:center;justify-content:center;text-decoration:none;border:2px solid var(--ink);border-radius:999px;padding:12px 17px;font-weight:950;box-shadow:4px 4px 0 var(--ink);background:var(--orange);color:var(--ink)}.btn.secondary{background:var(--cream)}.sponsor-note{font-size:13px;color:var(--muted);line-height:1.45}.footer{border-top:2px solid var(--ink);padding:34px 0;color:var(--muted);line-height:1.55}.footer a{font-weight:800;text-decoration:none;border-bottom:1px solid var(--line)}@media(max-width:760px){.wrap{width:min(100% - 24px,1040px)}.rule-strip .wrap,.nav-inner,.case-grid{align-items:flex-start;flex-direction:column;display:flex}.checks,.context-links,.cluster,.trust-grid,.source-grid{grid-template-columns:1fr}.hero h1{font-size:47px}}@media(prefers-reduced-motion:reduce){*,*::before,*::after{animation:none!important;transition:none!important;scroll-behavior:auto!important}}
    </style>
  </head>
  <body>
    <div class="rule-strip"><div class="wrap"><span><strong>Emergency rule:</strong> this page never needs recovery words.</span><span>Independent guide · no wallet data collection</span></div></div>
    <nav class="nav"><div class="wrap nav-inner"><a class="brand" href="/"><span class="brand-mark">X</span> XMR Safety Field Manual</a><div class="nav-links"><a href="/">Hub</a><a href="/#manual">Manual entries</a><a href="/about/">About</a><a href="/editorial-policy/">Editorial policy</a></div></div></nav>
    <div class="breadcrumbs wrap"><a href="/">Home</a><span>›</span><a href="/#manual">Manual entries</a><span>›</span><span>{page.title}</span></div>
    <header class="hero wrap"><div class="case-grid"><div><p class="kicker">Field manual entry · Reviewed {modified}</p><h1>{page.title}</h1><p class="answer">{page.directAnswer}</p><div class="meta-strip"><span>Independent education</span><span>No seed input</span><span>Not official support</span><span>No financial advice</span></div></div><aside class="case-card"><b>Do not paste secrets.</b><p>{page.scene}</p></aside></div></header>
    <main class="content wrap">
      <section class="section"><h2>Quick answer</h2><ul class="summary-list">{(depth.summary || [page.directAnswer]).map((item) => <li>{item}</li>)}</ul></section>
      <section class="section"><h2>Why trust this guide</h2><div class="trust-grid"><div class="trust-card"><strong>Independent and non-official</strong><p>{SITE.disclosure} This guide does not impersonate wallet support or ask for wallet material.</p></div><div class="trust-card"><strong>Reviewed for wallet-safety boundaries</strong><p>{editorial.policy}</p></div><div class="trust-card"><strong>People-first purpose</strong><p>The page is written for a user facing a risky wallet moment, not to funnel every visitor through a sponsored link.</p></div><div class="trust-card"><strong>Last reviewed</strong><p>{modified}. Update claims are limited to safety guidance that can be checked against public sources.</p></div></div></section>
      <section class="section"><h2>Checks before you act</h2><div class="checks">{page.checks.map((c) => <div class="check">{c}</div>)}</div><div class="cta"><a class="btn secondary" href="/">Back to field manual</a><a class="btn" href={SITE.referralUrl} target="_blank" rel="sponsored nofollow noopener">Continue to Cake Wallet</a></div><p class="sponsor-note">{SITE.referralDisclosure} We may earn from eligible actions after a click. This page remains independent and never asks for recovery phrases, private keys, wallet files, screenshots, or personal wallet details.</p></section>
      <section class="section source-box"><h2>Stop conditions</h2><p>Leave the flow and verify the source path again if any of these happen:</p><ul class="stop-list">{stopSignals.map((signal) => <li>{signal}</li>)}</ul></section>
      <section class="section prose"><h2>Practical notes</h2>{sections.map((section) => <article><h3>{section.heading}</h3><p>{section.body}</p></article>)}</section>
      <section class="section"><h2>Source trail</h2><div class="source-grid">{sourceTrail.map(([name, url, note]) => <article class="source-card"><strong><a href={url} target="_blank" rel="noopener">{name}</a></strong><p>{note}</p></article>)}</div></section>
      {contextual.length > 0 && <section class="section"><h2>Next checks</h2><div class="context-links">{contextual.map(([label, slug]) => <a href={`/${slug}/`}>{label} →</a>)}</div></section>}
      <section class="section faq"><h2>FAQ</h2>{page.faqs.map(([q,a]) => <details><summary>{q}</summary><p>{a}</p></details>)}</section>
      <section class="section"><h2>Related manual entries</h2><div class="cluster">{related.map((p) => <a href={`/${p.slug}/`}>{p.title} →</a>)}</div></section>
    </main>
    <footer class="footer wrap">Independent educational resource; not affiliated with Cake Wallet. This page never asks for recovery phrases, private keys, wallet files, screenshots, or personal wallet details. Read the <a href="/editorial-policy/">editorial policy</a> and <a href="/about/">about page</a>.</footer>
  </body>
</html>
